  {
    "name": "Sales Tax Calculation - US Multi-State",
    "description": "Calculate and record sales tax for US transactions",
    "eventType": "invoice.created",
    "priority": 90,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "invoice.country",
        "operator": "equals",
        "value": "US"
      },
      {
        "id": "cond_2",
        "field": "invoice.state",
        "operator": "notEquals",
        "value": null
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record sales tax liability",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "accounts-receivable-id"
        },
        "creditAccount": {
          "type": "dynamic",
          "lookup": {
            "type": "taxRate",
            "source": "invoice.state",
            "mapping": "sales-tax-payable-mapping"
          }
        },
        "amount": {
          "type": "formula",
          "formula": "{{invoice.subtotal}} * ({{taxRate}} / 100)",
          "rounding": "nearest",
          "precision": 2
        },
        "descriptionTemplate": "Sales tax - {{invoice.state}} - {{taxRate}}% - Invoice {{invoice.number}}",
        "referenceTemplate": "TAX-{{invoice.number}}",
        "metadata": {
          "taxRate": "{{taxRate}}",
          "taxableAmount": "{{invoice.subtotal}}",
          "taxJurisdiction": "{{invoice.state}}"
        }
      }
    ],
    "tags": ["tax", "sales-tax", "us", "compliance", "multi-state"],
    "config": {
      "requiresApproval": false,
      "runOnce": true,
      "taxConfig": {
        "taxInclusive": false,
        "taxOnShipping": true,
        "nexusStates": ["CA", "NY", "TX", "FL", "IL"]
      }
    }
  },
  {
    "name": "VAT Calculation - EU Reverse Charge",
    "description": "Handle VAT with reverse charge for EU B2B transactions",
    "eventType": "invoice.created",
    "priority": 90,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "invoice.country",
        "operator": "in",
        "value": ["GB", "DE", "FR", "IT", "ES", "NL", "BE", "IE"]
      },
      {
        "id": "cond_2",
        "field": "invoice.customerType",
        "operator": "equals",
        "value": "business"
      },
      {
        "id": "cond_3",
        "field": "invoice.hasVATNumber",
        "operator": "equals",
        "value": true
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record revenue (no VAT - reverse charge)",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "accounts-receivable-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "revenue-id"
        },
        "amount": {
          "type": "context",
          "contextPath": "invoice.subtotal"
        },
        "descriptionTemplate": "EU B2B sale - Reverse charge - {{invoice.customerName}} - {{invoice.country}}",
        "referenceTemplate": "INV-{{invoice.number}}",
        "metadata": {
          "customerVATNumber": "{{invoice.vatNumber}}",
          "reverseCharge": true,
          "taxPoint": "{{invoice.date}}"
        }
      },
      {
        "id": "action_2",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record VAT on purchase (if applicable)",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "vat-recoverable-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "vat-payable-id"
        },
        "amount": {
          "type": "formula",
          "formula": "{{invoice.subtotal}} * ({{vatRate}} / 100)",
          "rounding": "nearest",
          "precision": 2
        },
        "descriptionTemplate": "VAT reverse charge - {{invoice.country}} - {{vatRate}}%",
        "referenceTemplate": "VAT-{{invoice.number}}"
      }
    ],
    "tags": ["vat", "eu", "reverse-charge", "b2b", "compliance"],
    "config": {
      "requiresApproval": false,
      "runOnce": true,
      "validateVATNumber": true
    }
  },
  {
    "name": "Dividend Declaration and Payment",
    "description": "Record dividend declaration and subsequent payment",
    "eventType": "dividend.declared",
    "priority": 80,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "dividend.status",
        "operator": "equals",
        "value": "approved"
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record dividend declaration",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "retained-earnings-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "dividends-payable-id"
        },
        "amount": {
          "type": "context",
          "contextPath": "dividend.totalAmount"
        },
        "descriptionTemplate": "Dividend declared - {{dividend.date}} - ${{dividend.perShare}} per share",
        "referenceTemplate": "DIV-{{dividend.id}}-DEC"
      },
      {
        "id": "action_2",
        "type": "SCHEDULE_ACTION",
        "description": "Schedule dividend payment",
        "scheduleDate": "{{dividend.paymentDate}}",
        "action": {
          "type": "CREATE_LEDGER_ENTRY",
          "debitAccount": {
            "type": "fixed",
            "fixedAccountId": "dividends-payable-id"
          },
          "creditAccount": {
            "type": "fixed",
            "fixedAccountId": "cash-account-id"
          },
          "amount": {
            "type": "context",
            "contextPath": "dividend.totalAmount"
          },
          "descriptionTemplate": "Dividend payment - {{dividend.date}}",
          "referenceTemplate": "DIV-{{dividend.id}}-PMT"
        }
      }
    ],
    "tags": ["equity", "dividends", "shareholders", "distribution"],
    "config": {
      "requiresApproval": true,
      "runOnce": true
    }
  },
  {
    "name": "Stock Option Expense Recognition",
    "description": "Record share-based compensation expense",
    "eventType": "period.closing",
    "priority": 50,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "period.type",
        "operator": "equals",
        "value": "monthly"
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "BATCH_PROCESS",
        "description": "Calculate and record stock option expense",
        "batchType": "stockOptions",
        "filter": {
          "status": "vesting",
          "vestingStartDate": "{{period.startDate}}",
          "operator": "lessThanOrEqual"
        },
        "forEach": {
          "action": {
            "type": "CREATE_LEDGER_ENTRY",
            "debitAccount": {
              "type": "fixed",
              "fixedAccountId": "stock-compensation-expense-id"
            },
            "creditAccount": {
              "type": "fixed",
              "fixedAccountId": "additional-paid-in-capital-id"
            },
            "amount": {
              "type": "formula",
              "formula": "({{option.grantedOptions}} * {{option.fairValue}}) / {{option.vestingPeriodMonths}}",
              "rounding": "nearest",
              "precision": 2
            },
            "descriptionTemplate": "Stock option expense - {{option.grantDate}} - {{option.employeeName}}",
            "referenceTemplate": "STK-{{option.id}}-{{period.id}}"
          }
        }
      }
    ],
    "tags": ["equity", "stock-options", "compensation", "vesting"],
    "config": {
      "requiresApproval": true,
      "runOnce": false
    }
  },
  {
    "name": "Lease Liability - IFRS 16 Recognition",
    "description": "Record right-of-use asset and lease liability",
    "eventType": "lease.signed",
    "priority": 80,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "lease.type",
        "operator": "in",
        "value": ["operating", "finance"]
      },
      {
        "id": "cond_2",
        "field": "lease.term",
        "operator": "greaterThan",
        "value": 12
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record ROU asset and lease liability",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "right-of-use-asset-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "lease-liability-id"
        },
        "amount": {
          "type": "formula",
          "formula": "{{lease.presentValue}}",
          "rounding": "nearest",
          "precision": 2
        },
        "descriptionTemplate": "ROU asset and lease liability - {{lease.assetName}} - {{lease.term}} months",
        "referenceTemplate": "LEASE-{{lease.id}}-INIT"
      },
      {
        "id": "action_2",
        "type": "SCHEDULE_RECURRING",
        "description": "Schedule monthly lease payments",
        "scheduleType": "monthly",
        "startDate": "{{lease.startDate}}",
        "durationMonths": "{{lease.term}}",
        "actions": [
          {
            "type": "CREATE_LEDGER_ENTRY",
            "debitAccount": {
              "type": "fixed",
              "fixedAccountId": "lease-liability-id"
            },
            "creditAccount": {
              "type": "fixed",
              "fixedAccountId": "cash-account-id"
            },
            "amount": {
              "type": "context",
              "contextPath": "lease.monthlyPayment"
            },
            "descriptionTemplate": "Lease payment - {{lease.assetName}} - Month {{recurring.month}}",
            "referenceTemplate": "LEASE-{{lease.id}}-PMT-{{recurring.month}}"
          },
          {
            "type": "CREATE_LEDGER_ENTRY",
            "debitAccount": {
              "type": "fixed",
              "fixedAccountId": "interest-expense-id"
            },
            "creditAccount": {
              "type": "fixed",
              "fixedAccountId": "lease-liability-id"
            },
            "amount": {
              "type": "formula",
              "formula": "{{lease.outstandingBalance}} * ({{lease.interestRate}} / 12 / 100)",
              "rounding": "nearest",
              "precision": 2
            },
            "descriptionTemplate": "Lease interest - {{lease.assetName}} - Month {{recurring.month}}",
            "referenceTemplate": "LEASE-{{lease.id}}-INT-{{recurring.month}}"
          }
        ]
      }
    ],
    "tags": ["leases", "ifrs16", "asc842", "assets", "liabilities"],
    "config": {
      "requiresApproval": true,
      "runOnce": true,
      "amortizationSchedule": true
    }
  },
  {
    "name": "Customer Refund Processing",
    "description": "Handle customer refunds and reverse revenue",
    "eventType": "refund.processed",
    "priority": 90,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "refund.status",
        "operator": "equals",
        "value": "approved"
      },
      {
        "id": "cond_2",
        "field": "refund.amount",
        "operator": "greaterThan",
        "value": 0
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Reverse original revenue",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "revenue-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "accounts-receivable-id"
        },
        "amount": {
          "type": "context",
          "contextPath": "refund.amount"
        },
        "descriptionTemplate": "Revenue reversal - Refund {{refund.number}} - {{refund.customerName}}",
        "referenceTemplate": "REF-{{refund.id}}-REV"
      },
      {
        "id": "action_2",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record refund payment",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "accounts-receivable-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "cash-account-id"
        },
        "amount": {
          "type": "context",
          "contextPath": "refund.amount"
        },
        "descriptionTemplate": "Refund payment - {{refund.number}} - {{refund.customerName}}",
        "referenceTemplate": "REF-{{refund.id}}-PMT"
      },
      {
        "id": "action_3",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Reverse COGS if applicable",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "inventory-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "cogs-id"
        },
        "amount": {
          "type": "context",
          "contextPath": "refund.cogsAmount"
        },
        "descriptionTemplate": "COGS reversal - Refund {{refund.number}}",
        "referenceTemplate": "REF-{{refund.id}}-COGS",
        "condition": {
          "field": "refund.productReturned",
          "operator": "equals",
          "value": true
        }
      }
    ],
    "tags": ["refunds", "revenue", "customer-service", "adjustments"],
    "config": {
      "requiresApproval": true,
      "runOnce": true,
      "restockInventory": true
    }
  }
]