[
  {
    "name": "Revenue Recognition - Cash Basis",
    "description": "Recognize revenue when cash is received",
    "eventType": "payment.received",
    "priority": 100,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "payment.amount",
        "operator": "greaterThan",
        "value": 0
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Create revenue entry from cash payment",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "cash-account-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "revenue-account-id"
        },
        "amount": {
          "type": "context",
          "contextPath": "payment.amount"
        },
        "descriptionTemplate": "Revenue from payment {{payment.reference}}",
        "referenceTemplate": "REV-{{payment.id}}"
      }
    ],
    "tags": ["revenue", "cash-basis", "automation"],
    "config": {
      "requiresApproval": false,
      "runOnce": false
    }
  },
  {
    "name": "Revenue Recognition - Accrual Basis",
    "description": "Recognize revenue when invoice is created",
    "eventType": "invoice.created",
    "priority": 100,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "invoice.status",
        "operator": "equals",
        "value": "approved"
      },
      {
        "id": "cond_2",
        "field": "invoice.type",
        "operator": "equals",
        "value": "service"
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Create accounts receivable and revenue",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "accounts-receivable-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "service-revenue-id"
        },
        "amount": {
          "type": "context",
          "contextPath": "invoice.total"
        },
        "descriptionTemplate": "Service revenue from invoice {{invoice.number}} - {{invoice.customerName}}",
        "referenceTemplate": "INV-{{invoice.number}}"
      }
    ],
    "tags": ["revenue", "accrual-basis", "automation", "invoicing"],
    "config": {
      "requiresApproval": false,
      "runOnce": true
    }
  },
  {
    "name": "Deferred Revenue - Annual Subscription",
    "description": "Defer revenue for annual subscriptions",
    "eventType": "subscription.created",
    "priority": 90,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "subscription.billingPeriod",
        "operator": "equals",
        "value": "annual"
      },
      {
        "id": "cond_2",
        "field": "subscription.status",
        "operator": "equals",
        "value": "active"
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record payment and deferred revenue",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "cash-account-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "deferred-revenue-id"
        },
        "amount": {
          "type": "context",
          "contextPath": "subscription.amount"
        },
        "descriptionTemplate": "Annual subscription - {{subscription.customerName}} - {{subscription.plan}}",
        "referenceTemplate": "SUB-{{subscription.id}}"
      },
      {
        "id": "action_2",
        "type": "SCHEDULE_RECURRING",
        "description": "Schedule monthly revenue recognition",
        "scheduleType": "monthly",
        "startDate": "{{subscription.startDate}}",
        "durationMonths": 12,
        "actions": [
          {
            "type": "CREATE_LEDGER_ENTRY",
            "debitAccount": {
              "type": "fixed",
              "fixedAccountId": "deferred-revenue-id"
            },
            "creditAccount": {
              "type": "fixed",
              "fixedAccountId": "subscription-revenue-id"
            },
            "amount": {
              "type": "formula",
              "formula": "{{subscription.amount}} / 12",
              "rounding": "nearest",
              "precision": 2
            },
            "descriptionTemplate": "Monthly revenue recognition - {{subscription.customerName}} - Month {{recurring.month}}",
            "referenceTemplate": "SUB-{{subscription.id}}-M{{recurring.month}}"
          }
        ]
      }
    ],
    "tags": ["revenue", "deferred-revenue", "subscription", "saas", "recurring"],
    "config": {
      "requiresApproval": true,
      "runOnce": false,
      "maxRetries": 3
    }
  },
  {
    "name": "Expense Recognition - Bill Received",
    "description": "Record expense when bill is received",
    "eventType": "bill.received",
    "priority": 100,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "bill.status",
        "operator": "equals",
        "value": "approved"
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record expense and accounts payable",
        "debitAccount": {
          "type": "dynamic",
          "lookup": {
            "type": "category",
            "source": "bill.category",
            "mapping": {
              "office_supplies": "office-supplies-expense-id",
              "utilities": "utilities-expense-id",
              "rent": "rent-expense-id",
              "consulting": "consulting-expense-id",
              "software": "software-expense-id",
              "default": "other-expense-id"
            }
          }
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "accounts-payable-id"
        },
        "amount": {
          "type": "context",
          "contextPath": "bill.amount"
        },
        "descriptionTemplate": "Bill from {{bill.vendorName}} - {{bill.number}} - {{bill.category}}",
        "referenceTemplate": "BILL-{{bill.number}}"
      }
    ],
    "tags": ["expenses", "accounts-payable", "bills", "accrual"],
    "config": {
      "requiresApproval": true,
      "runOnce": true
    }
  },
  {
    "name": "Payment Processing - Credit Card Fees",
    "description": "Record credit card payment with fee deduction",
    "eventType": "payment.processed",
    "priority": 90,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "payment.method",
        "operator": "equals",
        "value": "credit_card"
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record net payment after fees",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "cash-account-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "accounts-receivable-id"
        },
        "amount": {
          "type": "formula",
          "formula": "{{payment.amount}} - ({{payment.amount}} * {{payment.feePercentage}} / 100) - {{payment.feeFixed}}",
          "rounding": "nearest",
          "precision": 2
        },
        "descriptionTemplate": "Credit card payment - {{payment.customerName}} - Invoice {{payment.invoiceNumber}}",
        "referenceTemplate": "PMT-{{payment.id}}"
      },
      {
        "id": "action_2",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record credit card processing fees",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "credit-card-fees-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "cash-account-id"
        },
        "amount": {
          "type": "formula",
          "formula": "({{payment.amount}} * {{payment.feePercentage}} / 100) + {{payment.feeFixed}}",
          "rounding": "nearest",
          "precision": 2
        },
        "descriptionTemplate": "Credit card processing fees - {{payment.reference}}",
        "referenceTemplate": "FEE-{{payment.id}}"
      }
    ],
    "tags": ["payments", "credit-card", "fees", "accounts-receivable"],
    "config": {
      "requiresApproval": false,
      "runOnce": true
    }
  },
  {
    "name": "Monthly Depreciation - Straight Line",
    "description": "Calculate and post monthly depreciation",
    "eventType": "period.closing",
    "priority": 50,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "period.type",
        "operator": "equals",
        "value": "monthly"
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "BATCH_PROCESS",
        "description": "Process depreciation for all assets",
        "batchType": "assets",
        "filter": {
          "status": "active",
          "depreciationMethod": "straight-line"
        },
        "forEach": {
          "action": {
            "type": "CREATE_LEDGER_ENTRY",
            "debitAccount": {
              "type": "fixed",
              "fixedAccountId": "depreciation-expense-id"
            },
            "creditAccount": {
              "type": "fixed",
              "fixedAccountId": "accumulated-depreciation-id"
            },
            "amount": {
              "type": "formula",
              "formula": "{{asset.cost}} / {{asset.usefulLife}} / 12",
              "rounding": "nearest",
              "precision": 2
            },
            "descriptionTemplate": "Monthly depreciation - {{asset.name}} - {{period.name}}",
            "referenceTemplate": "DEP-{{asset.id}}-{{period.id}}"
          }
        }
      }
    ],
    "tags": ["depreciation", "fixed-assets", "monthly", "scheduled"],
    "config": {
      "requiresApproval": true,
      "runOnce": false,
      "schedule": "0 0 1 * *"
    }
  },
  {
