  {
    "name": "Prepaid Insurance Amortization",
    "description": "Amortize prepaid insurance monthly",
    "eventType": "period.closing",
    "priority": 50,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "period.type",
        "operator": "equals",
        "value": "monthly"
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "BATCH_PROCESS",
        "description": "Amortize all active prepaid insurance policies",
        "batchType": "prepaidItems",
        "filter": {
          "type": "insurance",
          "status": "active"
        },
        "forEach": {
          "action": {
            "type": "CREATE_LEDGER_ENTRY",
            "debitAccount": {
              "type": "fixed",
              "fixedAccountId": "insurance-expense-id"
            },
            "creditAccount": {
              "type": "fixed",
              "fixedAccountId": "prepaid-insurance-id"
            },
            "amount": {
              "type": "formula",
              "formula": "{{item.totalAmount}} / {{item.termMonths}}",
              "rounding": "nearest",
              "precision": 2
            },
            "descriptionTemplate": "Insurance amortization - {{item.policyName}} - {{period.name}}",
            "referenceTemplate": "AMORT-{{item.id}}-{{period.id}}"
          }
        }
      }
    ],
    "tags": ["prepaid", "amortization", "insurance", "monthly"],
    "config": {
      "requiresApproval": true,
      "runOnce": false
    }
  },
