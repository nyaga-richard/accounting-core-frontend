  {
    "name": "Bad Debt Provision - Percentage of Sales",
    "description": "Calculate and record bad debt provision",
    "eventType": "period.closing",
    "priority": 50,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "period.type",
        "operator": "equals",
        "value": "monthly"
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "CREATE_LEDGER_ENTRY",
        "description": "Record bad debt provision",
        "debitAccount": {
          "type": "fixed",
          "fixedAccountId": "bad-debt-expense-id"
        },
        "creditAccount": {
          "type": "fixed",
          "fixedAccountId": "allowance-doubtful-accounts-id"
        },
        "amount": {
          "type": "formula",
          "formula": "{{period.creditSales}} * 0.025",
          "rounding": "nearest",
          "precision": 2
        },
        "descriptionTemplate": "Bad debt provision - {{period.name}} - 2.5% of credit sales",
        "referenceTemplate": "PROV-{{period.id}}"
      }
    ],
    "tags": ["bad-debt", "provision", "accounts-receivable", "monthly"],
    "config": {
      "requiresApproval": true,
      "runOnce": false
    }
  },
  {
    "name": "Foreign Exchange Revaluation",
    "description": "Revalue foreign currency balances at period end",
    "eventType": "period.closing",
    "priority": 40,
    "isActive": true,
    "conditions": [
      {
        "id": "cond_1",
        "field": "period.type",
        "operator": "equals",
        "value": "monthly"
      }
    ],
    "actions": [
      {
        "id": "action_1",
        "type": "BATCH_PROCESS",
        "description": "Revalue all foreign currency accounts",
        "batchType": "accounts",
        "filter": {
          "currency": "{{period.functionalCurrency}}",
          "operator": "notEquals"
        },
        "forEach": {
          "action": {
            "type": "CONDITIONAL",
            "conditions": [
              {
                "field": "revaluation.gain",
                "operator": "greaterThan",
                "value": 0
              }
            ],
            "trueAction": {
              "type": "CREATE_LEDGER_ENTRY",
              "debitAccount": {
                "type": "fixed",
                "fixedAccountId": "{{account.id}}"
              },
              "creditAccount": {
                "type": "fixed",
                "fixedAccountId": "fx-gain-id"
              },
              "amount": {
                "type": "context",
                "contextPath": "revaluation.gain"
              },
              "descriptionTemplate": "FX gain - {{account.code}} {{account.currency}} - {{period.name}}",
              "referenceTemplate": "FX-{{account.id}}-{{period.id}}"
            },
            "falseAction": {
              "type": "CREATE_LEDGER_ENTRY",
              "debitAccount": {
                "type": "fixed",
                "fixedAccountId": "fx-loss-id"
              },
              "creditAccount": {
                "type": "fixed",
                "fixedAccountId": "{{account.id}}"
              },
              "amount": {
                "type": "context",
                "contextPath": "revaluation.loss"
              },
              "descriptionTemplate": "FX loss - {{account.code}} {{account.currency}} - {{period.name}}",
              "referenceTemplate": "FX-{{account.id}}-{{period.id}}"
            }
          }
        }
      }
    ],
    "tags": ["fx", "forex", "revaluation", "multi-currency", "monthly"],
    "config": {
      "requiresApproval": true,
      "runOnce": false
    }
  },
  {
